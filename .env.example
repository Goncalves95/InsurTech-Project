# Copy this file to .env and fill in real values.
# .env is in .gitignore — NEVER commit secrets.

# ===== DATABASE =====
DB_URL=jdbc:postgresql://localhost:5432/insurtech
DB_USERNAME=insurtech
DB_PASSWORD=change_me

# ===== KAFKA =====
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ===== SECURITY / JWT =====
JWT_ISSUER_URI=http://localhost:8080/auth/realms/insurtech

# ===== OCR PROVIDER (Azure Document Intelligence) =====
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=https://<your-resource>.cognitiveservices.azure.com/
AZURE_DOCUMENT_INTELLIGENCE_KEY=change_me

# ===== BLOB STORAGE =====
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=<name>;AccountKey=<key>;EndpointSuffix=core.windows.net
AZURE_STORAGE_CONTAINER_NAME=medical-invoices

# ===== EMAIL (SendGrid) =====
# Required when SPRING_PROFILES_ACTIVE=azure — ignored by the dev stub.
SENDGRID_API_KEY=SG.change_me
SENDGRID_FROM_EMAIL=noreply@yourdomain.com
SENDGRID_FROM_NAME=InsurTech Platform

# ===== KEYCLOAK ADMIN (email resolver) =====
# Service account used by the backend to look up user emails from Keycloak.
# The service account must have the "view-users" role in the master realm.
KEYCLOAK_URL=http://localhost:8180
KEYCLOAK_REALM=insurtech
KEYCLOAK_ADMIN_CLIENT_ID=insurtech-backend
KEYCLOAK_ADMIN_CLIENT_SECRET=change_me

# ===== SPRING PROFILE =====
# Set to 'azure' to activate the real Azure adapters (Document Intelligence + Blob Storage + SendGrid).
# Leave empty or set to 'dev' to use the local stubs (no Azure account required).
SPRING_PROFILES_ACTIVE=dev
