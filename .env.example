# Copy this file to .env and fill in real values.
# .env is in .gitignore — NEVER commit secrets.

# ===== DATABASE =====
DB_URL=jdbc:postgresql://localhost:5432/insurtech
DB_USERNAME=insurtech
DB_PASSWORD=change_me

# ===== KAFKA =====
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ===== SECURITY / JWT =====
JWT_ISSUER_URI=http://localhost:8080/auth/realms/insurtech

# ===== OCR PROVIDER (Azure Document Intelligence) =====
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=https://<your-resource>.cognitiveservices.azure.com/
AZURE_DOCUMENT_INTELLIGENCE_KEY=change_me

# ===== BLOB STORAGE =====
AZURE_STORAGE_CONNECTION_STRING=change_me
AZURE_STORAGE_CONTAINER_NAME=medical-invoices
