<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <changeSet id="V002-1" author="insurtech-platform">
        <createTable tableName="tarmed_positions">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="claim_id" type="UUID">
                <constraints nullable="false"
                             foreignKeyName="fk_tarmed_positions_claim_id"
                             references="claims(id)"/>
            </column>
            <column name="tarmed_code" type="VARCHAR(10)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="VARCHAR(500)">
                <constraints nullable="false"/>
            </column>
            <column name="quantity" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="unit_price" type="DECIMAL(10, 2)">
                <constraints nullable="false"/>
            </column>
            <column name="total_price" type="DECIMAL(10, 2)">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex tableName="tarmed_positions" indexName="idx_tarmed_positions_claim_id">
            <column name="claim_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
