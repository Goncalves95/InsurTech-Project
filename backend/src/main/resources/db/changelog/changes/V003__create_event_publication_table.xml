<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <!--
        Spring Modulith event publication log table.
        Ensures at-least-once delivery: events are persisted before being published
        and marked complete only after successful processing.
    -->
    <changeSet id="V003-1" author="insurtech-platform">
        <createTable tableName="event_publication">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="listener_id" type="VARCHAR(512)">
                <constraints nullable="false"/>
            </column>
            <column name="event_type" type="VARCHAR(512)">
                <constraints nullable="false"/>
            </column>
            <column name="serialized_event" type="TEXT">
                <constraints nullable="false"/>
            </column>
            <column name="publication_date" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>
            <column name="completion_date" type="TIMESTAMP WITH TIME ZONE"/>
        </createTable>

        <createIndex tableName="event_publication" indexName="idx_event_publication_completion_date">
            <column name="completion_date"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
