<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <changeSet id="V001-1" author="insurtech-platform">
        <createTable tableName="claims">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="policy_holder_id" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="document_storage_key" type="VARCHAR(500)">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="VARCHAR(30)">
                <constraints nullable="false"/>
            </column>
            <column name="reviewer_note" type="TEXT"/>
            <column name="submitted_at" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>
            <column name="created_by" type="VARCHAR(100)"/>
            <column name="updated_by" type="VARCHAR(100)"/>
        </createTable>

        <createIndex tableName="claims" indexName="idx_claims_policy_holder_id">
            <column name="policy_holder_id"/>
        </createIndex>

        <createIndex tableName="claims" indexName="idx_claims_status">
            <column name="status"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
